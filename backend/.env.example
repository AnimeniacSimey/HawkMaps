# GoldenHawk AI — copy this file to `.env` and add ONE provider key.
#   cp .env.example .env
#
# Without any key, GoldenHawk still works using built-in keyword fallbacks.
# Pick whichever you have. If both are set, Claude is used.

# ── Option 1: Groq — FREE, no credit card ─────────────────────────────────
# Make your own key at https://console.groq.com/keys  (takes ~2 min).
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile   # optional override

# ── Option 2: Anthropic Claude ────────────────────────────────────────────
# Get a key at https://console.anthropic.com  → API Keys
# ANTHROPIC_API_KEY=sk-ant-...
# GOLDENHAWK_MODEL=claude-haiku-4-5     # optional override (cheap & fast)
