# GoldenHawk AI — copy this file to `.env` and fill in your key.
#   cp .env.example .env
#
# Get a key at https://console.anthropic.com  → API Keys
# Without a key, GoldenHawk still works using built-in keyword fallback replies.

ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the Claude model (default: claude-opus-4-8).
# For a cheaper/faster campus chatbot you can use: claude-haiku-4-5
# GOLDENHAWK_MODEL=claude-opus-4-8
