# GoldenHawk AI — copy this file to `.env` and fill in your key.
#   cp .env.example .env
#
# Get a key at https://console.anthropic.com  → API Keys
# Without a key, GoldenHawk still works using built-in keyword fallback replies.

ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the Claude model.
# Default is claude-haiku-4-5 (cheap & fast — plenty for a campus chatbot).
# Use a stronger model only if you need it, e.g. claude-sonnet-4-6.
# GOLDENHAWK_MODEL=claude-haiku-4-5
